# Coloring artwork: exclude raster art by default (sample PNGs, uploaded
# photos), but keep the actual line-art shipped with the app under version
# control so a fresh clone can build.
public/coloring/*.png
public/coloring/*.jpg
public/coloring/*.jpeg
public/coloring/*.webp
!public/coloring/prince.png
!public/coloring/princess-cute.png
!public/coloring/unicorn.png
!public/coloring/dinosaur.png
!public/coloring/police-car.png
!public/coloring/astronaut.png
!public/coloring/cupcake.png
